{
  "name": "fialho-clean-landing-page",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "astro check && eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{astro,ts,js}": [
