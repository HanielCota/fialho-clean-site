---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar.astro";
import Hero from "@/components/sections/Hero.astro";
import Stats from "@/components/sections/Stats.astro";
import Showcase from "@/components/sections/Showcase.astro";
import Features from "@/components/sections/Features.astro";
import Comparison from "@/components/sections/Comparison.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import Security from "@/components/sections/Security.astro";
import Changelog from "@/components/sections/Changelog.astro";
import Faq from "@/components/sections/Faq.astro";
import Download from "@/components/sections/Download.astro";
import Footer from "@/components/layout/Footer.astro";
---

<BaseLayout
  title="FialhoClean — Limpeza real para o seu Windows"
  description="FialhoClean remove bloatware, limpa registro e otimiza seu Windows. Gratuito, open source, sem telemetria."
>
  <Navbar />
  <main id="main">
    <Hero />
    <Stats />
    <Showcase />
    <Features />
    <Comparison />
    <HowItWorks />
    <Security />
    <Changelog />
    <Faq />
    <Download />
  </main>
  <Footer />
</BaseLayout>
