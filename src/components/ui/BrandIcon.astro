---
interface Props {
  path: string;
  size?: number;
  class?: string;
}

const { path, size = 18, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <path d={path}></path>
</svg>
