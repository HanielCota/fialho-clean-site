---
import PanelHeader from "@/components/sections/showcase/PanelHeader.astro";
---

<PanelHeader
  title="Deixe Mais Rápido"
  description="Ajustes de desempenho para o seu PC ficar mais ágil"
/>
<div class="speed-tabs">
  <button class="speed-tab speed-tab--active">Desempenho</button>
  <button class="speed-tab">Boot</button>
  <button class="speed-tab">Tarefas e Processos</button>
</div>
<div class="card-group">
  <div class="card-section-label">Plano de Energia</div>
  <div class="preset-row">
    <button class="preset">Economia</button>
    <button class="preset">Equilibrado</button>
    <button class="preset">Alto</button>
    <button class="preset mock-active">Máximo</button>
  </div>
</div>
<div class="card-group">
  <div class="card-section-label">Animações e Transparência</div>
  <div class="toggle-row">
    <div class="toggle-info">
      <span class="toggle-name">Reduzir Animações</span>
      <span class="toggle-hint">Desabilita efeitos visuais do Windows</span>
    </div>
    <div class="toggle-switch toggle-switch--on"><span class="toggle-switch-knob"></span></div>
  </div>
  <div class="toggle-row">
    <div class="toggle-info">
      <span class="toggle-name">Desativar Transparência</span>
      <span class="toggle-hint">Remove efeitos de acrylic/mica</span>
    </div>
    <div class="toggle-switch toggle-switch--on"><span class="toggle-switch-knob"></span></div>
  </div>
</div>
<div class="card-group">
  <div class="card-section-label">Desempenho em Jogos</div>
  <div class="toggle-row">
    <div class="toggle-info">
      <span class="toggle-name">Modo Gamer</span>
      <span class="toggle-hint">Pausa tarefas de fundo e libera CPU/GPU/RAM</span>
    </div>
    <div class="toggle-switch"><span class="toggle-switch-knob"></span></div>
  </div>
</div>

<style>
  .speed-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .speed-tab {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted-dim);
    background: none;
    border: none;
    padding: 0.55rem 0.95rem;
    border-bottom: 2px solid transparent;
    cursor: default;
    transition: color var(--duration-fast);
  }
  .speed-tab--active {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
  }

  .card-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card-section-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted-dim);
    letter-spacing: 0.02em;
  }

  .preset-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .preset {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.45rem 0.9rem;
    border-radius: 7px;
    border: 1px solid var(--color-border-mid);
    background-color: rgba(255, 255, 255, 0.02);
    color: var(--color-muted-dim);
    cursor: default;
    transition: all var(--duration-fast);
  }

  .toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0.75rem;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
  }
  .toggle-info {
    display: flex;
    flex-direction: column;
  }
  .toggle-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted);
  }
  .toggle-hint {
    font-size: var(--text-xs);
    color: var(--color-muted-dim);
  }

  .toggle-switch {
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background-color: #2a2a2a;
    position: relative;
    cursor: default;
    flex-shrink: 0;
    transition: background var(--duration-fast);
  }
  .toggle-switch-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--color-muted-deep);
    transition: all var(--duration-fast);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }
  .toggle-switch--on {
    background-color: var(--color-success);
  }
  .toggle-switch--on .toggle-switch-knob {
    left: 21px;
    background-color: #fff;
  }
</style>
