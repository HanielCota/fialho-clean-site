---
import AppTitlebar from "@/components/sections/showcase/AppTitlebar.astro";
import AppSidebar from "@/components/sections/showcase/AppSidebar.astro";
import type { ShowcasePanelId } from "@/types/showcase";

interface Props {
  activeItem: ShowcasePanelId;
}

const { activeItem } = Astro.props;
---

<div class="app-window" role="img" aria-label="Preview da interface do FialhoClean">
  <AppTitlebar />
  <div class="app-body">
    <AppSidebar activeItem={activeItem} />
    <div class="content">
      <slot />
    </div>
  </div>
</div>

<style>
  .app-window {
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--color-surface-deep);
    border: 1px solid var(--color-border-subtle);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 8px 24px -4px rgba(0, 0, 0, 0.5),
      0 24px 48px -8px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
  }
  .app-body {
    display: flex;
    min-height: 480px;
  }
  .content {
    flex: 1;
    padding: 1.75rem 2rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: linear-gradient(
      180deg,
      var(--color-surface-deep) 0%,
      var(--color-surface-deep) 100%
    );
  }

  @media (max-width: 768px) {
    .content {
      padding: 1.25rem 1rem;
    }
  }
</style>
