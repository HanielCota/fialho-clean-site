---
import Section from "@/components/ui/Section.astro";
import { Plus } from "@lucide/astro";
import { FAQS } from "@/constants/faq";
---

<Section
  id="faq"
  badge="FAQ"
  title="Perguntas frequentes"
  subtitle="As dúvidas que todo mundo tem antes de baixar."
>
  <div class="faq-grid">
    {
      FAQS.map((faq, index) => (
        <details class="faq-item" id={`faq-${index}`}>
          <summary class="faq-question">
            <span class="faq-num">{String(index + 1).padStart(2, "0")}</span>
            <span class="faq-question-text">{faq.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <Plus size={16} stroke-width={2.5} />
            </span>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</Section>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    max-width: 52rem;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .faq-item {
    interpolate-size: allow-keywords;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: border-color var(--duration-fast) ease;
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: var(--color-text);
  }

  .faq-item[open] {
    border-color: var(--color-text);
  }

  .faq-question {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: "";
  }

  .faq-num {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-muted);
    opacity: 0.5;
    letter-spacing: 0.04em;
    line-height: 1.6;
    flex-shrink: 0;
  }

  .faq-question-text {
    flex: 1;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.5;
  }

  .faq-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition:
      transform var(--duration-fast) ease,
      background-color var(--duration-fast) ease,
      color var(--duration-fast) ease;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background-color: var(--color-text);
    color: var(--color-surface);
    border-color: var(--color-text);
  }

  .faq-answer {
    display: block;
    max-height: 0;
    overflow: hidden;
    padding: 0 1.25rem 0;
    padding-left: calc(1.25rem + 0.7rem + 0.75rem);
    transition:
      max-height var(--duration-normal) var(--ease-out),
      padding-bottom var(--duration-normal) var(--ease-out);
  }

  .faq-item[open] .faq-answer {
    max-height: max-content;
    padding-bottom: 1.25rem;
  }

  .faq-answer p {
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-muted);
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }
</style>
