---
import Section from "@/components/ui/Section.astro";
import Card from "@/components/ui/Card.astro";
import { FEATURES } from "@/constants/features";
import type { FeatureIcon } from "@/types/feature";
import type { AstroComponentFactory } from "astro/runtime/server/render/astro/factory.js";
import { LayoutDashboard, Trash2, Zap, LayoutGrid, Wrench, ShieldCheck } from "@lucide/astro";

const iconComponents: Record<FeatureIcon, AstroComponentFactory> = {
  dashboard: LayoutDashboard,
  trash: Trash2,
  zap: Zap,
  apps: LayoutGrid,
  fix: Wrench,
  shield: ShieldCheck,
};
---

<Section
  id="recursos"
  badge="Recursos"
  title="Só o que faz sentido."
  subtitle="Ferramentas pra limpar e otimizar o Windows. Sem feature inútil pra encher slide."
>
  <div class="features-grid">
    {
      FEATURES.map((feature) => {
        const Icon = iconComponents[feature.icon];
        return <Card title={feature.title} description={feature.description} icon={Icon} />;
      })
    }
  </div>
</Section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
