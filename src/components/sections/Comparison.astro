---
import Section from "@/components/ui/Section.astro";
import BrandIcon from "@/components/ui/BrandIcon.astro";
import IconWindows from "@/components/ui/IconWindows.astro";
import {
  Check,
  Minus,
  X,
  Zap,
  Banknote,
  SquareCode,
  EyeOff,
  BellOff,
  Package,
  Trash2,
  Gauge,
  Wrench,
  UserX,
} from "@lucide/astro";
import { siCcleaner } from "simple-icons";
import { COMPARISON } from "@/constants/comparison";
import type { ComparisonIcon, ComparisonValue } from "@/types/comparison";
import type { AstroComponentFactory } from "astro/runtime/server/render/astro/factory.js";

const featureIcons: Record<ComparisonIcon, AstroComponentFactory> = {
  Banknote,
  SquareCode,
  EyeOff,
  BellOff,
  Package,
  Trash2,
  Gauge,
  Wrench,
  UserX,
};

function label(v: ComparisonValue): string {
  return v === true ? "Sim" : v === false ? "Não" : "Parcial";
}
---

<Section
  id="comparativo"
  badge="Por que Fialho Optimizer?"
  title="Sem compromisso. Sem armadilha."
  subtitle="Como o Fialho Optimizer se compara com as alternativas mais usadas."
>
  <div class="table-outer">
    <div class="table-wrap" role="region" aria-label="Tabela comparativa">
      <table>
        <thead>
          <tr>
            <th scope="col" class="col-feature"></th>
            <th scope="col" class="col-fialho">
              <div class="th-product">
                <div class="th-avatar th-avatar--fialho">
                  <Zap size={22} stroke-width={2} />
                </div>
                <span>Fialho Optimizer</span>
              </div>
            </th>
            <th scope="col" class="col-alt">
              <div class="th-product">
                <div class="th-avatar th-avatar--ccleaner">
                  <BrandIcon path={siCcleaner.path} size={22} />
                </div>
                <span>CCleaner</span>
              </div>
            </th>
            <th scope="col" class="col-alt">
              <div class="th-product">
                <div class="th-avatar th-avatar--windows">
                  <IconWindows size={22} />
                </div>
                <span>Windows Nativo</span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {
            COMPARISON.map((row) => {
              const FeatureIcon = featureIcons[row.icon];
              return (
                <tr>
                  <th scope="row" class="feature-name">
                    {FeatureIcon && (
                      <span class="feature-icon" aria-hidden="true">
                        <FeatureIcon size={18} stroke-width={1.75} />
                      </span>
                    )}
                    {row.feature}
                  </th>
                  {(["fialho", "ccleaner", "windows"] as const).map((col) => {
                    const v = row[col];
                    return (
                      <td class:list={["cell", col === "fialho" && "cell--fialho"]}>
                        {v === true && (
                          <Check
                            class="icon icon--yes"
                            size={16}
                            stroke-width={2.5}
                            aria-label="Sim"
                          />
                        )}
                        {v === false && (
                          <X class="icon icon--no" size={16} stroke-width={2.5} aria-label="Não" />
                        )}
                        {v === "partial" && (
                          <Minus
                            class="icon icon--partial"
                            size={16}
                            stroke-width={2.5}
                            aria-label="Parcial"
                          />
                        )}
                        <span class="sr-only">{label(v)}</span>
                      </td>
                    );
                  })}
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </div>
</Section>

<style>
  .table-outer {
    position: relative;
  }

  .table-wrap {
    overflow-x: auto;
    border-radius: 1rem;
    background-color: var(--color-surface);
    box-shadow:
      0 0 0 1px var(--color-border),
      0 1px 3px rgba(0, 0, 0, 0.4),
      0 4px 16px rgba(0, 0, 0, 0.2);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
  }

  th,
  td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  tr:last-child td {
    border-bottom: none;
  }

  .col-feature {
    width: 40%;
    text-align: left;
  }

  .col-fialho {
    background-color: color-mix(in oklch, var(--color-text) 4%, transparent);
  }

  .col-alt {
    width: 20%;
  }

  th {
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    vertical-align: bottom;
    padding-bottom: 1.1rem;
  }

  th.col-fialho {
    color: var(--color-text);
    background-color: color-mix(in oklch, var(--color-text) 6%, transparent);
    box-shadow: inset 0 3px 0 var(--color-text);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .th-product {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .th-avatar {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .th-avatar--fialho {
    background-color: color-mix(in oklch, var(--color-text) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-text) 20%, transparent);
    color: var(--color-text);
  }

  /* CCleaner brand color */
  .th-avatar--ccleaner {
    background-color: rgba(203, 45, 41, 0.1);
    border-color: rgba(203, 45, 41, 0.25);
    color: #cb2d29;
  }

  /* Windows brand color */
  .th-avatar--windows {
    background-color: rgba(0, 120, 212, 0.1);
    border-color: rgba(0, 120, 212, 0.25);
    color: #0078d4;
  }

  .cell--fialho {
    background-color: color-mix(in oklch, var(--color-text) 3%, transparent);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .feature-name {
    text-align: left;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .cell {
    vertical-align: middle;
  }

  .icon {
    display: inline-block;
  }

  .icon--yes {
    color: var(--color-success);
  }

  .icon--no {
    color: color-mix(in oklch, var(--color-muted) 50%, transparent);
  }

  .icon--partial {
    color: var(--color-warning);
  }

  tr:hover td {
    background-color: color-mix(in oklch, var(--color-text) 2%, transparent);
  }

  tr:hover .cell--fialho {
    background-color: color-mix(in oklch, var(--color-text) 6%, transparent);
  }
</style>
